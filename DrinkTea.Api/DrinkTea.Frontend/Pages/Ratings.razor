@page "/ratings"
@using DrinkTea.Shared.Models.Responses
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Рейтинг чаев</h2>
        <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/dashboard")'>В зал</button>
    </div>

    @if (isLoading)
    {
        <div class="text-center p-5"><div class="spinner-border text-success"></div></div>
    }
    else if (items == null || !items.Any())
    {
        <div class="alert alert-info">Пока нет данных по рейтингам.</div>
    }
    else
    {
        <div class="table-responsive bg-white shadow-sm rounded-4 p-3">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Чай</th>
                        <th>Средняя оценка</th>
                        <th>Отзывы</th>
                        <th>Последние публичные комментарии</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tea in items)
                    {
                        <tr>
                            <td>
                                <button class="btn btn-link p-0" @onclick='() => Nav.NavigateTo($"/teas/{tea.TeaId}")'>@tea.TeaName</button>
                            </td>
                            <td>⭐ @tea.AverageRating.ToString("0.00")</td>
                            <td>@tea.RatingsCount</td>
                            <td>
                                @if (!tea.RecentPublicComments.Any())
                                {
                                    <span class="text-muted">Нет комментариев других пользователей</span>
                                }
                                else
                                {
                                    @foreach (var comment in tea.RecentPublicComments)
                                    {
                                        <div class="small mb-1">
                                            <strong>@comment.UserName</strong>: @comment.Comment
                                        </div>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<TeaRatingListItemResponse>? items;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await Http.GetFromJsonAsync<List<TeaRatingListItemResponse>>("api/teas/ratings");
        }
        finally
        {
            isLoading = false;
        }
    }
}
