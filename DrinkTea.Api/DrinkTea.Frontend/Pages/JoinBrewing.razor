@page "/brewing/join/{sessionId:guid}"
@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Shared.Models.Responses
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4 text-center border-0">
            <h3 class="m-0 fw-bold">Подсадка гостя</h3>
            <p class="mb-0 opacity-75">Чайник: <strong>@(sessionInfo?.TeaName ?? "...")</strong></p>
        </div>
        
        <div class="card-body p-4">
            @if (activeVisits == null)
            {
                <div class="text-center p-4"><div class="spinner-border text-primary"></div></div>
            }
            else
            {
                <!-- ТЕКУЩИЙ СОСТАВ -->
                <div class="mb-4 text-center p-3 bg-light rounded-3 border">
                    <div class="small text-muted text-uppercase fw-bold mb-2">Уже пьют:</div>
                    <div class="d-flex flex-wrap justify-content-center gap-1">
                        @foreach (var p in sessionInfo?.Participants ?? new())
                        {
                            <span class="badge bg-secondary px-3 py-2">@p.Name</span>
                        }
                    </div>
                </div>

                <!-- ПОИСК ГОСТЯ -->
                <div class="mb-4 position-relative">
                    <label class="form-label fw-bold">Найдите гостя из зала</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text"
                               class="form-control border-start-0 shadow-none"
                               placeholder="Имя или стол..."
                               @bind="searchText"
                               @bind:event="oninput"
                               @onfocus="() => showResults = true" />
                    </div>

                    @if (showResults && !string.IsNullOrWhiteSpace(searchText))
                    {
                        <div class="list-group position-absolute w-100 shadow-lg z-3 mt-1" style="max-height: 200px; overflow-y: auto;">
                            @{
                                // Фильтруем: тех, кто в зале, и кого еще НЕТ в этом чайнике
                                var filtered = activeVisits
                                    .Where(v => (v.UserName ?? v.Note ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase))
                                    .Where(v => !sessionInfo?.Participants.Any(p => p.VisitId == v.Id) ?? true)
                                    .ToList();
                            }

                            @if (filtered.Any())
                            {
                                @foreach (var v in filtered)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                                            @onclick="() => SelectVisit(v)">
                                        <div>
                                            <div class="fw-bold">@(v.UserName ?? v.Note)</div>
                                            <small class="text-muted">Долг: @v.UnpaidDebt.ToString("N0") ₽</small>
                                        </div>
                                        <i class="bi bi-plus-circle text-success fs-5"></i>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-muted small p-3">Никого не нашли или гость уже в чайнике...</div>
                            }
                        </div>
                    }
                </div>

                <!-- ВЫБРАННЫЙ ГОСТЬ -->
                @if (selectedVisit != null)
                {
                    <div class="alert alert-success d-flex justify-content-between align-items-center p-3 animate__animated animate__fadeIn border-2">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-check-fill fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold">@(selectedVisit.UserName ?? selectedVisit.Note)</div>
                                <div class="small">Будет добавлен к счету</div>
                            </div>
                        </div>
                        <button type="button" class="btn-close" @onclick="ClearSelection"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger p-2 small">@error</div>
                }

                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-primary btn-lg shadow fw-bold py-3"
                            @onclick="HandleJoin"
                            disabled="@(selectedVisit == null || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        ПОДСАДИТЬ К ЧАЙНИКУ
                    </button>
                    <button class="btn btn-link text-muted mt-2" @onclick='() => Nav.NavigateTo("/")'>Отмена</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid sessionId { get; set; }
    
    private List<ActiveVisitDto>? activeVisits;
    private ActiveBrewingDto? sessionInfo;
    
    private string searchText = "";
    private bool showResults = false;
    private ActiveVisitDto? selectedVisit;
    
    private string? error;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            activeVisits = await Http.GetFromJsonAsync<List<ActiveVisitDto>>("api/visits/active");
            var allSessions = await Http.GetFromJsonAsync<List<ActiveBrewingDto>>("api/brewing/active");
            sessionInfo = allSessions?.FirstOrDefault(s => s.Id == sessionId);
            
            if (sessionInfo == null) Nav.NavigateTo("/");
        }
        catch { error = "Ошибка связи с сервером."; }
    }

    private void SelectVisit(ActiveVisitDto v)
    {
        selectedVisit = v;
        searchText = "";
        showResults = false;
    }

    private void ClearSelection() => selectedVisit = null;

    private async Task HandleJoin()
    {
        if (selectedVisit == null) return;
        isProcessing = true;
        error = null;

        var response = await Http.PatchAsJsonAsync($"api/brewing/{sessionId}/join", new JoinSessionDto { VisitId = selectedVisit.Id });

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            error = "Ошибка. Возможно, гость уже покинул зал или сессия закрыта.";
        }
        isProcessing = false;
    }
}
