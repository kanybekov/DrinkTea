@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

@code {
    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        
        if (state.User.Identity?.IsAuthenticated != true)
        {
            // Если аноним — просто уходим на логин
            Nav.NavigateTo("/login");
        }
    }
}

<div class="p-4">
    <h4 class="text-danger">Доступ ограничен</h4>
    <p>У вас нет прав мастера или сессия истекла.</p>
    <button class="btn btn-outline-primary" @onclick="GoToLogin">Перейти к входу</button>

    @code {
        @* ... ваш предыдущий код ... *@
        private void GoToLogin() => Nav.NavigateTo("/login", forceLoad: true);
    }
</div>
