@page "/visit/{visitId:guid}"
@using DrinkTea.Shared.Models.Responses
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/")'>
            <i class="bi bi-arrow-left"></i> В зал
        </button>
        <h4 class="fw-bold m-0">Детализация визита</h4>
    </div>

    @if (items == null)
    {
        <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 p-4 mb-3">
            <div class="text-center mb-4">
                <div class="text-muted small text-uppercase">Текущий счет</div>
                <div class="display-5 fw-bold text-danger">@items.Sum(x => x.ShareCost).ToString("N0") ₽</div>
            </div>

            <div class="list-group list-group-flush">
                @if (!items.Any())
                {
                    <div class="text-center py-4 text-muted italic">Гость пока ничего не заказывал.</div>
                }
                @foreach (var item in items)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <div>
                            <div class="fw-bold">@item.TeaName</div>
                            <div class="small text-muted">@item.Time.ToShortTimeString() • @item.Grams г</div>
                        </div>
                        <div class="fw-bold">@item.ShareCost.ToString("N0") ₽</div>
                    </div>
                }
            </div>
        </div>

        <div class="d-grid gap-2">
            <button class="btn btn-primary btn-lg shadow" @onclick='() => Nav.NavigateTo($"/brewing/new/{visitId}")'>
                <i class="bi bi-plus-circle me-1"></i> Добавить заварку
            </button>
            <button class="btn btn-success btn-lg shadow" @onclick='() => Nav.NavigateTo($"/checkout/{visitId}")'>
                <i class="bi bi-cash-stack me-1"></i> Перейти к оплате
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid visitId { get; set; }
    private List<VisitItemResponse>? items;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Используем эндпоинт, который мы ранее обсуждали в BrewingController
            items = await Http.GetFromJsonAsync<List<VisitItemResponse>>($"api/brewing/by-visit/{visitId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки чека: {ex.Message}");
        }
    }
}
