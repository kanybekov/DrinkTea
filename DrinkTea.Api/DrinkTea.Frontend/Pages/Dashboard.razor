@page "/"
@page "/dashboard"
@using DrinkTea.Shared.Models.Responses
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-cup-hot"></i> Зал</h2>
        <button class="btn btn-success shadow-sm" @onclick='() => Nav.NavigateTo("/checkin")'>
            <i class="bi bi-person-plus"></i> Новый гость
        </button>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }

    @if (activeVisits == null)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="mt-2 text-muted">Загружаем список гостей из базы...</p>
        </div>
    }
    else if (!activeVisits.Any())
    {
        <div class="alert alert-light text-center border p-5 shadow-sm">
            <h4 class="text-muted">В клубе сейчас никого нет</h4>
            <p>Нажмите кнопку выше, чтобы открыть первый визит.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var v in activeVisits)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 border-start border-4 @(v.UnpaidDebt > 1000 ? "border-danger" : "border-success")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="fw-bold text-primary">
                                    @(string.IsNullOrEmpty(v.UserName) ? v.Note : v.UserName)
                                </h5>
                                <span class="badge bg-light text-dark border">
                                    @v.StartTime.ToShortTimeString()
                                </span>
                            </div>
                            
                            <div class="mt-3">
                                <div class="small text-muted">Долг за чай:</div>
                                <div class="h3 fw-bold @(v.UnpaidDebt > 0 ? "text-danger" : "")">
                                    @v.UnpaidDebt ₽
                                </div>
                            </div>

                            @if (v.UserDeposit.HasValue && v.UserDeposit.Value > 0)
                            {
                                <div class="alert alert-success p-1 px-2 small mb-0 mt-2">
                                    <i class="bi bi-wallet2"></i> Депозит: <b>@v.UserDeposit.Value ₽</b>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
                            <button class="btn btn-primary w-100" @onclick='() => Nav.NavigateTo($"/visit/{v.Id}")'>
                                Чай
                            </button>
                            <button class="btn btn-outline-success w-100" @onclick='() => Nav.NavigateTo($"/checkout/{v.Id}")'>
                                Чек
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ActiveVisitDto>? activeVisits;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            errorMessage = null;
            // Важно: адрес должен соответствовать твоему контроллеру VisitsController
            activeVisits = await Http.GetFromJsonAsync<List<ActiveVisitDto>>("api/visits/active");
        }
        catch (Exception ex)
        {
            errorMessage = "Ошибка связи с API. Проверьте, запущен ли бэкенд и настройки CORS.";
            activeVisits = new(); // Убираем индикатор загрузки
            Console.WriteLine($"Ошибка десериализации или сети: {ex.Message}");
        }
    }
}
