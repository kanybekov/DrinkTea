@page "/brewing/new"
@page "/brewing/new/{visitId:guid}"
@attribute [Authorize(Roles = "Master")]

@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Shared.Models.Responses
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow border-0 p-4">
        <h3 class="fw-bold mb-4 text-primary"><i class="bi bi-plus-square"></i> Новая заварка</h3>

        @if (teas == null || activeVisits == null)
        {
            <div class="text-center p-5"><div class="spinner-border text-success"></div></div>
        }
        else
        {
            <!-- 1. Выбор чая -->
            <div class="mb-3">
                <label class="form-label fw-bold">Чай со склада</label>
                <select class="form-select form-select-lg" @bind="dto.TeaId">
                    <option value="">-- Выберите сорт --</option>
                    @foreach (var tea in teas)
                    {
                        <option value="@tea.Id">@tea.Name (@tea.CurrentStock г) — @tea.BrewPrice ₽/г</option>
                    }
                </select>
            </div>

            <!-- 2. Граммы -->
            <div class="mb-4">
                <label class="form-label fw-bold">Вес (граммы)</label>
                <div class="input-group input-group-lg">
                    <input type="number" @bind="dto.Grams" class="form-control" placeholder="7.0" step="0.1" />
                    <span class="input-group-text">г</span>
                </div>
            </div>

            <!-- 3. Выбор участников (Multi-select) -->
            <div class="mb-4">
                <label class="form-label fw-bold">Кто пьет? (можно выбрать нескольких)</label>
                <div class="list-group">
                    @foreach (var v in activeVisits)
                    {
                        <label class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <input class="form-check-input me-2" type="checkbox"
                                       checked="@dto.VisitIds.Contains(v.Id)"
                                       @onchange="e => ToggleVisit(v.Id, e.Value)">
                                    @(string.IsNullOrEmpty(v.UserName) ? v.Note : v.UserName)
                                </div>
                                <span class="badge bg-light text-dark border">@v.UnpaidDebt ₽</span>
                            </label>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }

                <div class="d-flex gap-3">
                    <button class="btn btn-light btn-lg flex-grow-1" @onclick='() => Nav.NavigateTo("/")'>Отмена</button>
                    <button class="btn btn-primary btn-lg flex-grow-1 shadow" @onclick="HandleStart">
                        Запустить чаепитие
                    </button>
                </div>
            }
        </div>
    </div>

@code {
    [Parameter] public Guid? visitId { get; set; } // Добавь '?' чтобы GUID мог быть null
    private StartBrewingDto dto = new();
    private List<TeaInventoryResponse>? teas;
    private List<ActiveVisitDto>? activeVisits;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            teas = await Http.GetFromJsonAsync<List<TeaInventoryResponse>>("api/teas/inventory");
            activeVisits = await Http.GetFromJsonAsync<List<ActiveVisitDto>>("api/visits/active");
            
            // Инициализируем список ID участников
            dto.VisitIds = new List<Guid>();
            
            // Если мы пришли из карточки конкретного гостя (ID передан в URL)
            if (visitId.HasValue && visitId != Guid.Empty)
            {
                dto.VisitIds.Add(visitId.Value);
            }
            
            dto.Grams = 7;
        }
        catch
        {
            error = "Ошибка загрузки данных.";
        }
    }


    private void ToggleVisit(Guid id, object? isChecked)
    {
        if ((bool)(isChecked ?? false))
        {
            if (!dto.VisitIds.Contains(id)) dto.VisitIds.Add(id);
        }
        else
        {
            dto.VisitIds.Remove(id);
        }
    }

    private async Task HandleStart()
    {
        if (dto.TeaId == Guid.Empty || dto.Grams <= 0 || !dto.VisitIds.Any())
        {
            error = "Выберите чай, вес и хотя бы одного гостя.";
            return;
        }

        var response = await Http.PostAsJsonAsync("api/brewing/start", dto);
        if (response.IsSuccessStatusCode) Nav.NavigateTo("/");
        else error = "Ошибка. Возможно, на складе не хватает чая.";
    }
}
