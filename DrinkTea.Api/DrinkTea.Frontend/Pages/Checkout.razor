@page "/checkout/{visitId:guid}"
@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Shared.Enums
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="bg-primary p-4 text-white text-center">
            <h3 class="m-0 fw-bold">Оплата счета</h3>
            <p class="mb-0 opacity-75">@(visit?.UserName ?? visit?.Note ?? "Загрузка...")</p>
        </div>

        <div class="card-body p-4">
            @if (items == null)
            {
                <div class="text-center p-4"><div class="spinner-border text-primary"></div></div>
            }
            else
            {
                <div class="mb-4">
                    <label class="text-muted small fw-bold">ДЕТАЛИЗАЦИЯ</label>
                    <div class="list-group list-group-flush">
                        @foreach (var item in items)
                        {
                            <div class="list-group-item d-flex justify-content-between border-0 px-0">
                                <span>@item.TeaName (@item.Grams г)</span>
                                <span class="fw-bold">@item.ShareCost ₽</span>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between h4 fw-bold">
                        <span>ИТОГО:</span>
                        <span class="text-danger">@visit?.UnpaidDebt.ToString("N0") ₽</span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Способ оплаты</label>
                    <select class="form-select form-select-lg" @bind="selectedMethod">
                        <option value="@PaymentMethod.Cash">💵 Наличные</option>
                        <option value="@PaymentMethod.Card">💳 Карта</option>
                        @if (visit?.UserDeposit > 0)
                        {
                            <option value="@PaymentMethod.Internal">🪙 Депозит (доступно @visit.UserDeposit ₽)</option>
                        }
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger p-2">@error</div>
                }

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg shadow" @onclick="HandlePayment" disabled="@loading">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Закрыть визит
                    </button>
                    <button class="btn btn-link text-muted" @onclick='() => Nav.NavigateTo("/")'>Назад</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid visitId { get; set; }
    private List<VisitItemResponse>? items;
    private ActiveVisitDto? visit;
    private PaymentMethod selectedMethod = PaymentMethod.Cash;
    private string? error;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Загружаем данные из API
            var allActive = await Http.GetFromJsonAsync<List<ActiveVisitDto>>("api/visits/active");
            visit = allActive?.FirstOrDefault(v => v.Id == visitId);
            items = await Http.GetFromJsonAsync<List<VisitItemResponse>>($"api/brewing/by-visit/{visitId}");
        }
        catch { error = "Не удалось загрузить данные чека."; }
    }

    private async Task HandlePayment()
    {
        loading = true;
        error = null;

        var request = new CheckoutRequest
        {
            Method = selectedMethod,
            InternalAmount = selectedMethod == PaymentMethod.Internal ? (visit?.UnpaidDebt ?? 0) : 0,
            ExternalAmount = selectedMethod != PaymentMethod.Internal ? (visit?.UnpaidDebt ?? 0) : 0
        };

        var response = await Http.PostAsJsonAsync($"api/visits/{visitId}/checkout", request);

        if (response.IsSuccessStatusCode) Nav.NavigateTo("/");
        else error = "Ошибка оплаты. Проверьте баланс гостя.";
        
        loading = false;
    }
}
