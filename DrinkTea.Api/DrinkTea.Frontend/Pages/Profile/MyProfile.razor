@page "/my-profile"
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Frontend.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IUsersApiService UsersApi

<div class="container mt-4" style="max-width: 600px;">
    @if (profile == null)
    {
        <div class="text-center p-5"><div class="spinner-border text-success"></div></div>
    }
    else
    {
        <div class="card shadow border-0 rounded-4 overflow-hidden">
            <div class="bg-success p-4 text-white text-center">
                <i class="bi bi-person-circle" style="font-size: 3rem;"></i>
                @* Теперь Name берем напрямую из корня profile *@
                <h2 class="mt-2 fw-bold">@profile.Name</h2>
                <span class="badge bg-white text-success px-3">Постоянный гость</span>
            </div>
            
            <div class="card-body p-4">
                <div class="row text-center mb-4">
                    <div class="col">
                        <div class="small text-muted">Мой баланс</div>
                        @* Balance напрямую из корня *@
                        <div class="h3 fw-bold text-success">@profile.Balance.ToString("N0") ₽</div>
                    </div>
                    <div class="col">
                        <div class="small text-muted">Визитов</div>
                        @* VisitsCount напрямую из корня *@
                        <div class="h3 fw-bold">@profile.VisitsCount</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(profile.FavoriteTea))
                {
                    <div class="alert alert-info text-center py-2">
                        <i class="bi bi-star-fill me-2"></i> Любимый чай: <strong>@profile.FavoriteTea</strong>
                    </div>
                }

                <h6 class="fw-bold mb-3">Последние чаепития:</h6>
                <div class="list-group list-group-flush">
                    @* Используем RecentBrews вместо RecentVisits *@
                    @foreach (var brew in profile.RecentBrews)
                    {
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <div>
                                <div class="fw-bold">@brew.TeaName</div>
                                <div class="small text-muted">@brew.Date.ToShortDateString()</div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold">@brew.Amount.ToString("N0") ₽</div>
                            </div>
                        </div>
                    }
                </div>

                <h6 class="fw-bold mt-4 mb-3"><i class="bi bi-bag-check me-2"></i>Покупки с собой:</h6>
                <div class="list-group list-group-flush border rounded-3">
                    @if (!profile.RecentSales.Any())
                    {
                        <div class="list-group-item text-muted small italic">Покупок пока не было.</div>
                    }
                    @foreach (var sale in profile.RecentSales)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold">@sale.TeaName</div>
                                <div class="small text-muted">@sale.Date.ToShortDateString() • @sale.Grams.ToString("N0") г</div>
                            </div>
                            <div class="fw-bold text-primary">@sale.TotalPrice.ToString("N0") ₽</div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
</div>

@code {
    private CustomerFullProfileResponse? profile;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profile = await UsersApi.GetMyFullProfileAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка профиля: {ex.Message}");
        }
    }
}
