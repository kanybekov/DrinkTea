@page "/user/{userId:guid}/topup"
@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Shared.Enums
@using DrinkTea.Frontend.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject IUsersApiService UsersApi
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="bg-primary p-4 text-white text-center">
            <h3 class="m-0 fw-bold">Пополнение баланса</h3>
            <p class="mb-0 opacity-75">Клиент: @(user?.FullName ?? "Загрузка...")</p>
        </div>

        <div class="card-body p-4">
            @if (user == null)
            {
                <div class="text-center p-4"><div class="spinner-border text-primary"></div></div>
            }
            else
            {
                <div class="mb-4 text-center">
                    <label class="text-muted small fw-bold d-block mb-1">ТЕКУЩИЙ БАЛАНС</label>
                    <div class="h2 fw-bold text-success">@user.Balance.ToString("N0") ₽</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Сумма пополнения</label>
                    <div class="input-group input-group-lg">
                        <input type="number" @bind="request.Amount" class="form-control" placeholder="1000" />
                        <span class="input-group-text">₽</span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Способ оплаты (как приняли деньги)</label>
                    <select class="form-select form-select-lg" @bind="request.Method">
                        <option value="@PaymentMethod.Cash">💵 Наличные</option>
                        <option value="@PaymentMethod.Card">💳 Карта</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger p-2 small">@error</div>
                }

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg shadow" @onclick="HandleTopUp" disabled="@(request.Amount <= 0 || loading)">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Пополнить депозит
                    </button>
                    <button class="btn btn-link text-muted" @onclick='() => Nav.NavigateTo("/")'>Отмена</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid userId { get; set; }
    private UserListItemDto? user;
    private TopUpRequest request = new() { Method = PaymentMethod.Cash };
    private string? error;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Загружаем данные пользователя через существующий API
            var allUsers = await UsersApi.GetAllAsync();
            user = allUsers?.FirstOrDefault(u => u.Id == userId);
        }
        catch { error = "Не удалось загрузить данные пользователя."; }
    }

    private async Task HandleTopUp()
    {
        loading = true;
        error = null;

        var response = await UsersApi.TopUpAsync(userId, request);

        if (response.IsSuccessStatusCode)
        {
            // Возвращаемся в зал (или можно в профиль гостя)
            Nav.NavigateTo("/");
        }
        else
        {
            error = "Ошибка при пополнении. Проверьте связь с сервером.";
        }
        loading = false;
    }
}