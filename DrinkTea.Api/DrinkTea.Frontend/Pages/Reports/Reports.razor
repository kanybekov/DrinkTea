@page "/reports"
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Shared.Enums
@using DrinkTea.Frontend.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject IReportsApiService ReportsApi

<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow border-0 rounded-4 overflow-hidden mb-4">
        <div class="bg-dark p-4 text-white d-flex justify-content-between align-items-center">
            <h3 class="m-0 fw-bold"><i class="bi bi-calendar-check text-success me-2"></i>Итоги смены</h3>
            <div class="d-flex gap-2">
                <input type="date" @bind="reportDate" class="form-control" />
                <button class="btn btn-success" @onclick="LoadAllData">Показать</button>
            </div>
        </div>

        <div class="card-body p-4">
            @if (report == null)
            {
                <div class="text-center p-4"><div class="spinner-border text-success"></div></div>
            }
            else
            {
                <div class="row g-3 mb-4">
                    @foreach (var total in report.Totals)
                    {
                        <div class="col-md-4">
                            <div class="p-3 rounded-4 border text-center bg-light">
                                <div class="small text-muted mb-1">@GetMethodName(total.Key)</div>
                                <div class="h3 fw-bold m-0 text-dark">@total.Value.ToString("N0") ₽</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ТАБЛИЦА ДЕТАЛИЗАЦИИ -->
    <div class="card shadow border-0 rounded-4 p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-list-ul me-2"></i>Журнал операций</h5>
        @if (details == null)
        {
            <div class="text-center"><div class="spinner-border spinner-border-sm"></div></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Время</th>
                            <th>Клиент</th>
                            <th>Описание</th>
                            <th>Метод</th>
                            <th class="text-end">Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in details)
                        {
                            <tr>
                                <td class="small">@tx.Time.ToShortTimeString()</td>
                                <td class="fw-bold">@(tx.UserName ?? "Гость")</td>
                                <td class="small text-muted">@tx.Description</td>
                                <td><span class="badge bg-light text-dark border">@GetMethodName(tx.Method)</span></td>
                                <td class="text-end fw-bold">@tx.Amount.ToString("N0") ₽</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private CashReportResponse? report;
    private List<TransactionDetailResponse>? details;
    private DateTime reportDate = DateTime.Today;

    protected override async Task OnInitializedAsync() => await LoadAllData();

    private async Task LoadAllData()
    {
        report = null;
        details = null;
        report = await ReportsApi.GetDailyReportAsync(reportDate);
        details = await ReportsApi.GetDetailedReportAsync(reportDate);
    }

    private string GetMethodName(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => "Наличные",
        PaymentMethod.Card => "Карта",
        PaymentMethod.Internal => "Депозит",
        _ => method.ToString()
    };
}
