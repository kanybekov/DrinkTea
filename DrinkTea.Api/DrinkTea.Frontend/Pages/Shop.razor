@page "/shop"
@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="bg-dark p-4 text-white text-center">
            <h3 class="m-0 fw-bold"><i class="bi bi-cart4 text-success me-2"></i>Розничная продажа</h3>
            <p class="mb-0 opacity-75">Продажа чая без открытия счета в зале</p>
        </div>

        <div class="card-body p-4">
            @if (teas == null)
            {
                <div class="text-center p-4"><div class="spinner-border text-success"></div></div>
            }
            else
            {
                <!-- 1. Выбор чая -->
                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted text-uppercase">Сорт чая</label>
                    <select class="form-select form-select-lg" @bind="request.TeaId">
                        <option value="">-- Выберите чай --</option>
                        @foreach (var t in teas)
                        {
                            <option value="@t.Id">@t.Name (@t.CurrentStock г) — @t.SalePrice ₽/г</option>
                        }
                    </select>
                </div>

                <!-- 2. Вес -->
                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted text-uppercase">Вес (граммы)</label>
                    <div class="input-group input-group-lg">
                        <input type="number" @bind="request.Grams" @bind:event="oninput" class="form-control" placeholder="50" />
                        <span class="input-group-text">г</span>
                    </div>
                </div>

                <!-- 3. Расчет стоимости -->
                <div class="alert alert-secondary text-center mb-4">
                    <small class="text-muted d-block">ИТОГО К ОПЛАТЕ</small>
                    <div class="h2 fw-bold m-0">@CurrentTotal.ToString("N0") ₽</div>
                </div>

                <!-- 4. Способ оплаты -->
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted text-uppercase">Способ оплаты</label>
                    <select class="form-select form-select-lg" @bind="request.PaymentMethod">
                        <option value="@PaymentMethod.Cash">💵 Наличные</option>
                        <option value="@PaymentMethod.Card">💳 Карта</option>
                        <option value="@PaymentMethod.Internal">🪙 С депозита</option>
                    </select>
                </div>

                <!-- 5. Поиск клиента (только если Internal) -->
                @if (request.PaymentMethod == PaymentMethod.Internal)
                {
                    <div class="mb-4 position-relative">
                        <label class="form-label fw-bold small text-muted text-uppercase">Поиск покупателя</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text"
                                   class="form-control border-start-0 shadow-none"
                                   placeholder="Имя клиента..."
                                   @bind="searchText"
                                   @bind:event="oninput"
                                   @onfocus="() => showResults = true" />
                        </div>

                        @if (showResults && !string.IsNullOrWhiteSpace(searchText))
                        {
                            <div class="list-group position-absolute w-100 shadow-lg z-3 mt-1" style="max-height: 200px; overflow-y: auto;">
                                @{
                                    var filtered = users?.Where(u => u.FullName.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
                                }

                                @if (filtered != null && filtered.Any())
                                {
                                    @foreach (var u in filtered)
                                    {
                                        <button type="button"
                                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2"
                                                @onclick="() => SelectUser(u)">
                                            <div>
                                                <div class="fw-bold">@u.FullName</div>
                                                <small class="text-muted">Баланс: @u.Balance.ToString("N0") ₽</small>
                                            </div>
                                            <i class="bi bi-plus-lg text-success"></i>
                                        </button>
                                    }
                                }
                                else
                                {
                                    <div class="list-group-item text-muted small p-3">Клиент не найден</div>
                                }
                            </div>
                        }

                        @if (selectedUser != null)
                        {
                            <div class="alert alert-info d-flex justify-content-between align-items-center p-2 mt-2 mb-0 animate__animated animate__fadeIn">
                                <span><i class="bi bi-person-check-fill me-2"></i><strong>@selectedUser.FullName</strong></span>
                                <button type="button" class="btn-close" @onclick="ClearSelection" style="font-size: 0.7rem;"></button>
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger p-2 small">@error</div>
                }

                <div class="d-grid gap-2">
                    <button class="btn btn-success btn-lg shadow fw-bold" @onclick="HandleSale" disabled="@(IsInvalid || loading)">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        ОФОРМИТЬ ПРОДАЖУ
                    </button>
                    <button class="btn btn-link text-muted" @onclick='() => Nav.NavigateTo("/")'>Отмена</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private SaleRequest request = new() { PaymentMethod = PaymentMethod.Cash, Grams = 0 };
    private List<TeaInventoryResponse>? teas;
    private List<UserListItemDto>? users;
    
    private string searchText = "";
    private bool showResults = false;
    private UserListItemDto? selectedUser;

    private string? error;
    private bool loading;

    private decimal CurrentTotal => (teas?.FirstOrDefault(t => t.Id == request.TeaId)?.SalePrice ?? 0) * request.Grams;

    private bool IsInvalid => request.TeaId == Guid.Empty || request.Grams <= 0 ||
                             (request.PaymentMethod == PaymentMethod.Internal && selectedUser == null);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/users");
            if (response.IsSuccessStatusCode)
            {
                users = await response.Content.ReadFromJsonAsync<List<UserListItemDto>>();
            }
            
            teas = await Http.GetFromJsonAsync<List<TeaInventoryResponse>>("api/teas/inventory");
        }
        catch (Exception ex)
        {
            error = "Ошибка связи: " + ex.Message;
        }
    }

    private void SelectUser(UserListItemDto u)
    {
        selectedUser = u;
        request.UserId = u.Id;
        searchText = "";
        showResults = false;
    }

    private void ClearSelection()
    {
        selectedUser = null;
        request.UserId = null;
    }

    private async Task HandleSale()
    {
        loading = true;
        error = null;

        var response = await Http.PostAsJsonAsync("api/sales", request);

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            error = string.IsNullOrEmpty(msg) ? "Ошибка. Проверьте склад или баланс." : msg;
        }
        loading = false;
    }
}
