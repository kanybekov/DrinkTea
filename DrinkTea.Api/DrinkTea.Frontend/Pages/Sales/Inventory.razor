@page "/inventory"
@using DrinkTea.Shared.Models.Responses
@using DrinkTea.Shared.Models.Requests
@using DrinkTea.Frontend.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Master")]
@inject ITeaApiService TeaApi

<div class="container mt-4">
    <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded-3 border-bottom">
        <h2 class="fw-bold m-0 text-primary">
            <i class="bi bi-box-seam me-2"></i>Склад чая
        </h2>
        <button class="btn btn-success btn-lg shadow-sm" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i> Новый сорт
        </button>
    </div>

    @if (teas == null)
    {
        <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!teas.Any())
    {
        <div class="alert alert-info text-center shadow-sm">На складе пока нет ни одного сорта чая.</div>
    }
    else
    {
        <!-- ТАБЛИЦА СКЛАДА -->
        <div class="table-responsive bg-white shadow-sm rounded-4 p-3">
            <table class="table align-middle table-hover m-0">
                <thead class="table-light">
                    <tr>
                        <th>Сорт чая</th>
                        <th>Остаток</th>
                        <th>Цена (Заварка)</th>
                        <th>Цена (Продажа)</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tea in teas)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold fs-5">@tea.Name</div>
                                <small class="text-muted">ID: @tea.Id.ToString().Substring(0, 8)</small>
                            </td>
                            <td>
                                <span class="badge @(tea.CurrentStock < 50 ? "bg-danger" : "bg-success") fs-6 px-3 py-2">
                                    <i class="bi @(tea.CurrentStock < 50 ? "bi-exclamation-triangle" : "bi-check-circle") me-1"></i>
                                    @tea.CurrentStock.ToString("N1") г
                                </span>
                            </td>
                            <td>
                                @if (editingTeaId == tea.Id)
                                {
                                    <input type="number" @bind="editBrewPrice" class="form-control form-control-sm" style="width: 80px;" />
                                }
                                else
                                {
                                    <span>@tea.BrewPrice ₽/г</span>
                                }
                            </td>
                            <td>
                                @if (editingTeaId == tea.Id)
                                {
                                    <input type="number" @bind="editSalePrice" class="form-control form-control-sm" style="width: 80px;" />
                                }
                                else
                                {
                                    <span>@tea.SalePrice ₽/г</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (editingTeaId == tea.Id)
                                {
                                    <button class="btn btn-sm btn-success me-1" @onclick="() => SavePrices(tea.Id)">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-sm btn-light" @onclick="() => editingTeaId = null">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartEdit(tea)" title="Изменить цены">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
        
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenRestockModal(tea)">
                                        Приход
                                    </button>
                                }
                            </td>


                            <td class="text-end">
                                <button class="btn btn-outline-primary shadow-sm" @onclick="() => OpenRestockModal(tea)">
                                    <i class="bi bi-plus-circle me-1"></i> Приход
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- МОДАЛКА: НОВЫЙ СОРТ -->
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">Добавить новый чай</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Название</label>
                        <input type="text" @bind="createReq.Name" class="form-control form-control-lg" placeholder="например: Да Хун Пао" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small">Начальный вес (г)</label>
                        <div class="input-group">
                            <input type="number" @bind="createReq.InitialStock" class="form-control" placeholder="500" />
                            <span class="input-group-text">г</span>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small">Цена заварки</label>
                            <input type="number" @bind="createReq.BrewPrice" class="form-control" placeholder="15" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small">Цена продажи</label>
                            <input type="number" @bind="createReq.SalePrice" class="form-control" placeholder="25" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-link text-muted me-auto" @onclick="() => showCreateModal = false">Отмена</button>
                    <button class="btn btn-success px-4" @onclick="HandleCreate"
                            disabled="@(string.IsNullOrWhiteSpace(createReq.Name) || loading)">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Создать сорт
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- МОДАЛКА: ПРИХОД ТОВАРА -->
@if (selectedTea != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Приход: @selectedTea.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4 text-center">
                        <small class="text-muted text-uppercase fw-bold">Текущий остаток: @selectedTea.CurrentStock г</small>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Добавить вес (граммы)</label>
                        <div class="input-group input-group-lg">
                            <input type="number" @bind="restockReq.Amount" class="form-control" placeholder="500" />
                            <span class="input-group-text">г</span>
                        </div>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small text-muted">Новая цена заварки</label>
                            <input type="number" @bind="restockReq.NewBrewPrice" class="form-control" placeholder="@selectedTea.BrewPrice" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted">Новая цена продажи</label>
                            <input type="number" @bind="restockReq.NewSalePrice" class="form-control" placeholder="@selectedTea.SalePrice" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-link text-muted me-auto" @onclick="CloseModal">Отмена</button>
                    <button class="btn btn-primary px-4" @onclick="HandleRestock"
                            disabled="@(restockReq.Amount <= 0 || loading)">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Принять товар
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TeaInventoryResponse>? teas;
    private TeaInventoryResponse? selectedTea;
    
    private CreateTeaRequest createReq = new();
    private RestockRequest restockReq = new();

    private Guid? editingTeaId;
    private decimal editBrewPrice;
    private decimal editSalePrice;
    
    private bool showCreateModal;
    private bool loading;

    protected override async Task OnInitializedAsync() => await LoadTeas();

    private async Task LoadTeas()
    {
        try { teas = await TeaApi.GetInventoryAsync(); }
        catch { /* Лог ошибки */ }
    }

    private void OpenCreateModal()
    {
        createReq = new CreateTeaRequest();
        showCreateModal = true;
    }

    private void OpenRestockModal(TeaInventoryResponse tea)
    {
        selectedTea = tea;
        restockReq = new RestockRequest { Amount = 0 };
    }

    private void CloseModal() => selectedTea = null;

    private async Task HandleCreate()
    {
        loading = true;
        var res = await TeaApi.CreateAsync(createReq);
        if (res.IsSuccessStatusCode)
        {
            await LoadTeas();
            showCreateModal = false;
        }
        loading = false;
    }

    private async Task HandleRestock()
    {
        if (selectedTea == null) return;
        loading = true;
        var res = await TeaApi.RestockAsync(selectedTea.Id, restockReq);
        if (res.IsSuccessStatusCode)
        {
            await LoadTeas();
            CloseModal();
        }
        loading = false;
    }

    private void StartEdit(TeaInventoryResponse tea)
    {
        editingTeaId = tea.Id;
        editBrewPrice = tea.BrewPrice;
        editSalePrice = tea.SalePrice;
    }

    private async Task SavePrices(Guid id)
    {
        var res = await TeaApi.UpdatePricesAsync(id, editBrewPrice, editSalePrice);
        if (res.IsSuccessStatusCode)
        {
            editingTeaId = null;
            await LoadTeas();
        }
    }

}
